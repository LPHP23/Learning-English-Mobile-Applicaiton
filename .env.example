# .env.example
# Copy to .env and fill in your values

# Supabase (get from supabase.com > Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic - NEVER put this in .env for client app
# Store in Supabase Secrets: supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx   ← SERVER SIDE ONLY

# MyMemory Translation — tăng quota dịch miễn phí (optional)
# Đăng ký email tại https://mymemory.translated.net/doc/keygen.php
# EXPO_PUBLIC_MYMEMORY_EMAIL=your-email@example.com

# ElevenLabs (optional - for premium TTS)
# Store in Supabase Secrets: supabase secrets set ELEVENLABS_API_KEY=xxx
# ELEVENLABS_API_KEY=xxx          ← SERVER SIDE ONLY
